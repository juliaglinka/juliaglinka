#!/bin/bash

echo "Running pre-commit checks..."

echo "Checking PureScript formatting..."
npx purs-tidy check src test
if [ $? -ne 0 ]; then
  echo "Formatting check failed. Run 'npm run format' to fix."
  exit 1
fi

echo "Building PureScript project..."
spago build
if [ $? -ne 0 ]; then
  echo "Build failed."
  exit 1
fi

echo "Running tests..."
spago test
if [ $? -ne 0 ]; then
  echo "Tests failed."
  exit 1
fi

echo "All pre-commit checks passed!"
exit 0
