{
  "private": true,
  "devDependencies": {
    "esbuild": "^0.27.3",
    "parcel": "2.7.0",
    "purescript": "^0.15.4",
    "purs-tidy": "^0.10.0",
    "spago": "^0.20.9",
    "tailwindcss": "^3.4.0"
  },
  "scripts": {
    "build": "spago build",
    "build:css": "npx tailwindcss -i ./dev/input.css -o ./dev/styles.css",
    "build:js": "npx esbuild dev/entry.js --bundle --format=esm --outfile=dev/bundle.js --minify",
    "watch:css": "npx tailwindcss -i ./dev/input.css -o ./dev/styles.css --watch",
    "serve": "npm run build && npm run build:css && npm run build:js && ./serve.sh",
    "build:gh": "./build-gh.sh",
    "test": "spago test",
    "lint": "npx purs-tidy check src test",
    "format": "npx purs-tidy format-in-place src test",
    "format:check": "npx purs-tidy check src test",
    "ci": "npm run lint && npm run build && npm run test"
  }
}
